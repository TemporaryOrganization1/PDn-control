# PostgreSQL (for update history tracking only)
POSTGRES_HOST=geoip-db
POSTGRES_PORT=5432
POSTGRES_USER=geoip
POSTGRES_PASSWORD=geoip_secret
POSTGRES_DB=geoip

# Service
SERVER_PORT=8080

# GeoIP MMDB Update
GEOIP_RELEASE_TAG=20260605
GEOIP_MMDB_URL=https://github.com/Skiddle-ID/geoip2-mirror/releases/download
UPDATE_INTERVAL=168h    # 7 days
FIRST_UPDATE_DELAY=30s  # wait 30s on startup for DB to be ready

# MMDB file storage
MMDB_DIR=/data/geoip